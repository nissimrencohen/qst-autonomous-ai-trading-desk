# RAG Service — environment overrides (prefix: RAG_)
# Copy to .env and fill in values. Never commit .env to version control.

RAG_LOG_LEVEL=INFO

# Deployment mode: dev | aws
RAG_ENVIRONMENT=dev

# Vector store: chroma (production) | memory (dev/CI)
RAG_STORE_BACKEND=memory
RAG_CHROMA_PATH=./chroma_db

# Summarizer backend:
#   extractive — deterministic, no LLM (dev/CI)
#   ollama     — local Ollama directly (legacy single-provider)
#   litellm    — multi-provider router: Groq → Gemini → OpenAI → Ollama
#   bedrock    — AWS Bedrock (production cloud, requires AWS creds)
RAG_SUMMARIZER_BACKEND=extractive

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
RAG_BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
RAG_AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Ollama (legacy / last-resort) ────────────────────────────────────────────
RAG_OLLAMA_URL=http://localhost:11434
RAG_OLLAMA_MODEL=llama3.1:8b

# ── LLM Router (used when RAG_SUMMARIZER_BACKEND=litellm) ────────────────────
RAG_LLM_PROVIDER_CHAIN=groq,gemini,openai,ollama
RAG_GROQ_API_KEY=
RAG_GROQ_MODEL=llama-3.3-70b-versatile
RAG_GOOGLE_API_KEY=
RAG_GEMINI_MODEL=gemini/gemini-2.5-flash
RAG_OPENAI_API_KEY=
RAG_OPENAI_MODEL=gpt-4o-mini
