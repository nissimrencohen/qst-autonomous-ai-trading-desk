# Agentic Engine — environment overrides (prefix: AGENTIC_)
# Copy to .env and fill in values. Never commit .env to version control.

AGENTIC_LOG_LEVEL=INFO

# Deployment mode:
#   dev (default) — multi-provider LLM router with local Ollama fallback
#   aws           — exclusive AWS Bedrock, no fallback chain
AGENTIC_ENVIRONMENT=dev

# Engine backend:
#   deterministic — rule-based (dev/CI, no LLM)
#   crew          — CrewAI crew via LLM router (requires at least one provider key)
AGENTIC_ENGINE_BACKEND=deterministic

# ── AWS Bedrock (used when AGENTIC_ENVIRONMENT=aws) ──────────────────────────
AGENTIC_BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6
AGENTIC_AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── LLM Router (used when AGENTIC_ENVIRONMENT != aws) ────────────────────────
# Comma-separated provider priority (left = first tried on each call).
AGENTIC_LLM_PROVIDER_CHAIN=groq,gemini,openai,ollama

# Groq — fastest free-tier inference (recommended first)
AGENTIC_GROQ_API_KEY=
AGENTIC_GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini
AGENTIC_GOOGLE_API_KEY=
AGENTIC_GEMINI_MODEL=gemini/gemini-2.5-flash

# OpenAI
AGENTIC_OPENAI_API_KEY=
AGENTIC_OPENAI_MODEL=gpt-4o-mini

# Local Ollama — last-resort fallback
AGENTIC_OLLAMA_URL=http://host.docker.internal:11434
AGENTIC_OLLAMA_MODEL=qwen3:8b

# ── Web search ────────────────────────────────────────────────────────────────
AGENTIC_WEB_SEARCH_ENABLED=true
# Tavily gives higher-quality financial results; leave blank to use DuckDuckGo.
AGENTIC_TAVILY_API_KEY=

# ── Conversational memory ─────────────────────────────────────────────────────
# sqlite (default) | memory (CI/tests) | dynamodb (AWS production)
AGENTIC_MEMORY_BACKEND=sqlite
AGENTIC_MEMORY_DB_PATH=./data/agent_memory.db
# DynamoDB settings (only when AGENTIC_MEMORY_BACKEND=dynamodb)
AGENTIC_DYNAMODB_TABLE=trading-desk-memory
AGENTIC_DYNAMODB_REGION=us-east-1

# ── v1.4: Durable RunStore (PostgreSQL) ──────────────────────────────────────
# "memory" (default) or "postgres" (durable, multi-worker-safe)
AGENTIC_RUN_STORE_BACKEND=memory
# Used when AGENTIC_RUN_STORE_BACKEND=postgres
AGENTIC_POSTGRES_DSN=postgresql+psycopg2://trading:trading@postgres:5432/trading_desk

# ── v1.4: Broker Integration (Alpaca) ────────────────────────────────────────
# Paper trading (safe default). Set AGENTIC_ALPACA_PAPER=false for live.
# Get keys at https://alpaca.markets (free paper account).
AGENTIC_ALPACA_KEY=
AGENTIC_ALPACA_SECRET=
AGENTIC_ALPACA_PAPER=true

# ── v1.4: Multi-source Market Data ───────────────────────────────────────────
# Provider chain: first available key wins. yfinance requires no key.
AGENTIC_MARKET_DATA_CHAIN=polygon,alpaca,yfinance
# Polygon.io API key (free Starter plan covers real-time data)
AGENTIC_POLYGON_API_KEY=

# ── JWT Authentication + DB-backed RBAC ───────────────────────────────────────
# When false (default), /analyze, /synthesize, /analyze/batch stay open in dev/CI.
# The DB-backed login flow (POST /auth/token) and role gating work regardless,
# because the React dashboard uses the returned role to gate the UI.
AGENTIC_AUTH_ENABLED=false
# Generate with: openssl rand -hex 32
AGENTIC_AUTH_SECRET=changeme-generate-with-openssl-rand-hex-32
# Seed credentials — applied ONLY on first boot, when the users table is empty.
AGENTIC_AUTH_ADMIN_PASSWORD=admin
AGENTIC_AUTH_USER_PASSWORD=user
# SQLite file backing the RBAC users table (admin / standard roles).
AGENTIC_USERS_DB_PATH=./data/users.db

# ── v1.4: Batch Concurrency ───────────────────────────────────────────────────
# Max simultaneous CrewAI crews in a /analyze/batch call.
# 3 is safe for Groq free tier (30 RPM); raise to 5-7 with paid keys.
AGENTIC_BATCH_CONCURRENCY=3

# ── Social media ingestion pipeline ──────────────────────────────────────────
# Set AGENTIC_SOCIAL_PIPELINE_ENABLED=false to disable entirely (default: true).
AGENTIC_SOCIAL_PIPELINE_ENABLED=true
# How often to poll Reddit + Telegram (seconds). Default: 900 (15 minutes).
AGENTIC_SOCIAL_POLL_INTERVAL_S=900

# Reddit — script-app credentials from https://www.reddit.com/prefs/apps
# Leave blank to skip Reddit ingestion.
AGENTIC_REDDIT_CLIENT_ID=
AGENTIC_REDDIT_CLIENT_SECRET=
AGENTIC_REDDIT_USER_AGENT=TradingDesk:v1.0 (read-only research bot; contact: your@email.com)
# Comma-separated subreddits (without "r/"):
AGENTIC_REDDIT_SUBREDDITS=wallstreetbets,investing,stocks,Daytrading
AGENTIC_REDDIT_POST_LIMIT=25
AGENTIC_REDDIT_COMMENT_LIMIT=5

# Telegram — credentials from https://my.telegram.org (User-API, preferred)
# Leave blank to skip Telegram ingestion.
AGENTIC_TELEGRAM_API_ID=
AGENTIC_TELEGRAM_API_HASH=
# Optional: use bot token instead of user-API (bot must be a channel member)
AGENTIC_TELEGRAM_BOT_TOKEN=
# Comma-separated public channel usernames (without "@"):
AGENTIC_TELEGRAM_CHANNELS=
AGENTIC_TELEGRAM_HISTORY_LIMIT=20
